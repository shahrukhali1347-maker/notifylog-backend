{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/register", "dest": "/api/register.js" },
    { "src": "/api/analyze", "dest": "/api/analyze.js" },
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/api/admin/devices", "dest": "/api/admin/devices.js" }
  ]
}
